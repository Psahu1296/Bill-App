# ── Server ────────────────────────────────────────────────────────────────────
PORT=5002
NODE_ENV=development

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_string

# ── Frontend URLs ─────────────────────────────────────────────────────────────
# POS frontend dev server (Vite)
FRONTEND_URL=http://localhost:5173
# Deployed customer-facing ordering app
CUSTOMER_APP_URL=https://your-customer-app.vercel.app
SERVER_URL=http://localhost:5002

# ── PhonePe Payment Gateway ───────────────────────────────────────────────────
# Get credentials from PhonePe merchant dashboard
# Use UAT values for testing, replace with PRODUCTION for live
PHONEPE_MERCHANT_ID=PGTESTPAYUAT
PHONEPE_SALT_KEY=your_phonepe_salt_key
PHONEPE_SALT_INDEX=1
PHONEPE_ENV=UAT

# ── Cloudflare Named Tunnel ───────────────────────────────────────────────────
# 1. Go to Cloudflare Zero Trust → Networks → Tunnels
# 2. Create a tunnel, copy the token shown during connector setup
# 3. Add a Public Hostname: domain = your-domain.com, service = http://localhost:5002
CLOUDFLARE_TUNNEL_TOKEN=paste_your_tunnel_token_here
# The public domain configured in the tunnel's Public Hostname
CLOUDFLARE_TUNNEL_URL=https://your-domain.com
